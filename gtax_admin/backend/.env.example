# Environment variables for AI Trading Platform

# App Settings
APP_NAME="AI Trading Platform"
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production

# Database
DATABASE_URL=sqlite+aiosqlite:///./trading.db
# For PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/trading

# Redis
REDIS_URL=redis://localhost:6379/0

# API Keys
NEWS_API_KEY=your-newsapi-key
ALPHA_VANTAGE_KEY=your-alphavantage-key

# Trading API Keys (Optional - Paper trading by default)
ALPACA_API_KEY=your-alpaca-key
ALPACA_SECRET_KEY=your-alpaca-secret
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# AI Weights
AI_TECHNICAL_WEIGHT=0.4
AI_PATTERN_WEIGHT=0.3
AI_SENTIMENT_WEIGHT=0.3
AI_CONFIDENCE_THRESHOLD=0.65

# Risk Management
MAX_POSITION_SIZE=0.1
DEFAULT_STOP_LOSS=0.02
DEFAULT_TAKE_PROFIT=0.05
